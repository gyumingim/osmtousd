# 루트 — 새 Isaac Sim 프로젝트용. kmit/ 은 자체 .gitignore 보유.

# Python
__pycache__/
*.pyc
*.pyo

# Env / 자격증명 (절대 커밋 금지)
.env
*.key
*.secret
.secrets

# 대용량 — 데이터셋·가중치·체크포인트·아카이브 (재생성/다운 가능, 커밋 금지)
poc_city_render/dataset_v1/
poc_city_render/dataset_pose/
poc_city_render/dataset_quad/
poc_city_render/realtest/
poc_city_render/confusers/
poc_city_render/runs/
poc_city_render/benchmarks/
*.pt
*.pth
*.onnx
*.engine
*.tar.gz
*.zip
*.hdr
poc_city_render/*.png
poc_city_render/*.log

# Isaac/USD 생성물 (재생성 가능)
# *.usda
# *.usdz

# 가상환경 (절대 커밋 금지, 5.9GB)
venv/
*/venv/
drone_det/venv/

# 대용량 3D 에셋·아카이브 (원본 보유/다운로드 가능)
*.rar
*.fbx
*.glb
*.gltf
*.obj
*.usd
*.usdc
assets/env_airport/
assets/env_forest/
assets/env_island/
assets/incoming/
assets/nvidia_city_demo/
assets/city_buildings/
assets/shibuya/
assets/shibuya_large/
assets/explora_src/

# 렌더 결과물 (재생성 가능)
results/*.png
poc_city_render/*_shots/

# 캐시
*.pkl
